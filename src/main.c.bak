/* Includes */
#include <rvem.h>

const uint8_t program[] = {
  0x13, 0x07, 0xf0, 0x03, 
  0x13, 0x05, 0x17, 0x00, 
  0xb7, 0x06, 0x00, 0x09, 
  0x93, 0x05, 0x00, 0x02, 
  0x13, 0x08, 0xa0, 0x00, 
  0x93, 0x08, 0xf0, 0xff, 
  0x93, 0x07, 0x00, 0x00, 
  0x6f, 0x00, 0xc0, 0x00, 
  0x23, 0xa0, 0xb6, 0x00, 
  0x93, 0x87, 0x17, 0x00, 
  0xe3, 0x9c, 0xe7, 0xfe, 
  0x13, 0x06, 0x00, 0x00, 
  0x33, 0x03, 0xe5, 0x40, 
  0x63, 0x1c, 0x66, 0x00, 
  0x13, 0x07, 0xf7, 0xff, 
  0x23, 0xa0, 0x06, 0x01, 
  0xe3, 0x1c, 0x17, 0xfd, 
  0x13, 0x05, 0x00, 0x00, 
  0x6f, 0x00, 0x80, 0x02, 
  0xb3, 0x77, 0xe6, 0x00, 
  0x93, 0xb7, 0x17, 0x00, 
  0xb3, 0x07, 0xf0, 0x40, 
  0x93, 0xf7, 0xa7, 0x00, 
  0x93, 0x87, 0x07, 0x02, 
  0x23, 0xa0, 0xf6, 0x00, 
  0x23, 0xa0, 0xb6, 0x00, 
  0x13, 0x06, 0x16, 0x00, 
  0x6f, 0xf0, 0x9f, 0xfc, 
};

/* Entry point */
int main(int argc, char *argv[]) {
  rv32i_t cpu;

  /* Initialise cpu */
  init(&cpu);

  /* Initialise memory */
  uint8_t *mem = malloc(0x1000);
  uint8_t *uart = malloc(4);
  for (size_t i = 0; i < sizeof(program); i++) mem[i] = program[i];
  add_region(&cpu, 0, 0x1000, mem);
  add_region(&cpu, 0x9000000, 4, uart);

  /* Reset */
  reset(&cpu);

  /* Main loop */
  while (getchar() != 'q') step(&cpu, true);

  /* Cleanup */
  destroy(&cpu);
  free(mem);
  free(uart);
  return 0;
}
